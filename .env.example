# ──────────────────────────────────────────────────────────────
# MediCare Connect — Environment Variables
# Copy this file to .env and fill in the values.
# NEVER commit .env to git.
# ──────────────────────────────────────────────────────────────

# ─── Supabase / Postgres ───────────────────────────────────────
# Get this from: Supabase Dashboard → Settings → Database → Connection String (URI mode)
# Use the "Transaction" pooler URL for app connections (port 6543)
# Use the "Session" pooler or direct URL for migrations (port 5432)
SUPABASE_DB_URL=postgresql://postgres:Bharanivoice555@db.uyibvkgbxfbarlocdovq.supabase.co:5432/postgres

# ─── Encryption Keys ──────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
# APP_ENCRYPT_KEY: used by pgp_sym_encrypt/decrypt for PII columns (name, phone, dob)
# APP_HMAC_KEY: used by hmac() for phone_hash (DIFFERENT key from encrypt key)
# ⚠️  If you lose these keys, encrypted data is unrecoverable.
# Store them in a password manager immediately.
APP_ENCRYPT_KEY=replace_with_64_char_random_hex_string
APP_HMAC_KEY=replace_with_different_64_char_random_hex_string

# ─── Set after running seed.py ────────────────────────────────
# The UUID of the pilot clinic row created by seed.py
PILOT_CLINIC_ID=

# ─── Phase 2 onward (fill in when you reach that phase) ───────
GROQ_API_KEY=
DEEPGRAM_API_KEY=
ELEVENLABS_API_KEY=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# ─── Phase 3 onward ───────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=

# ─── Phase 4 onward ───────────────────────────────────────────
QDRANT_URL=
QDRANT_API_KEY=
OPENAI_API_KEY=    # for embeddings (text-embedding-3-small)
